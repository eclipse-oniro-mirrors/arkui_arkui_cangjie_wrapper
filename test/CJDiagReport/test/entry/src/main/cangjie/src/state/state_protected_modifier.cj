/*
 * 测试场景：@State 禁止 protected 修饰符
 * 预期错误：MacroErrorCode.UnexpectedModifier
 * 开发范式：误用 protected 限制状态可见性
 */
package ohos_app_cangjie_entry.state

import ohos.base.*
import ohos.arkui.component.*
import ohos.arkui.state_management.*
import ohos.arkui.state_macro_manage.*

@Entry
@Component
class StateProtectedModifierView {
    @State protected var count: Int64 = 0

    func build(): Unit {
        Column() {}
    }
}
